# Docker Compose / dev container (repo root).
# Compose auto-loads this file for ${VAR} substitution in docker-compose.yaml.

# ROS distro for the Docker image build (do not rename to ROS_DISTRO — your shell may set that).
TB_ROS_DISTRO=jazzy

# TurtleBot3 model passed into Gazebo spawn (3 or 4).
TURTLEBOT_MODEL=3

# Dev container only: auto-launch gpr_coverage on start (post-start.sh). Default off for reviewers.
DEVCONTAINER_AUTO_START_DEMO=false
