<?xml version="1.0"?>
<!-- GPR polygon scan world: concave "M" mission boundary + interior obstacles.
     Interior vertices match scan_area.polygon_vertices in gpr_coverage.yaml (scenario:=polygon).
     Walls sit just outside each polygon edge (same convention as gpr_scan.sdf.xacro). -->
<sdf version="1.6" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="headless" default="false"/>

  <xacro:property name="wall_thickness" value="0.10"/>
  <xacro:property name="wall_height" value="0.60"/>
  <xacro:property name="wall_corner_overlap" value="0.10"/>

  <xacro:macro name="static_box_obstacle" params="name x y sx sy sz r:=0.45 g:=0.45 b:=0.45">
    <model name="${name}">
      <static>true</static>
      <pose>${x} ${y} ${sz / 2.0} 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${sx} ${sy} ${sz}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${sx} ${sy} ${sz}</size>
            </box>
          </geometry>
          <material>
            <ambient>${r} ${g} ${b} 1</ambient>
            <diffuse>${r} ${g} ${b} 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
  </xacro:macro>

  <!-- Wall segment along polygon edge (x0,y0)->(x1,y1); CCW polygon, wall offset outward. -->
  <xacro:macro name="polygon_edge_wall" params="name x0 y0 x1 y1">
    <xacro:property name="dx" value="${x1 - x0}"/>
    <xacro:property name="dy" value="${y1 - y0}"/>
    <xacro:property name="edge_len" value="${sqrt(dx * dx + dy * dy)}"/>
    <xacro:property name="seg_len" value="${edge_len + wall_corner_overlap}"/>
    <xacro:property name="mx" value="${(x0 + x1) / 2.0}"/>
    <xacro:property name="my" value="${(y0 + y1) / 2.0}"/>
    <xacro:property name="yaw" value="${atan2(dy, dx)}"/>
    <xacro:property name="ox" value="${dy / edge_len}"/>
    <xacro:property name="oy" value="${-dx / edge_len}"/>
    <xacro:property name="wx" value="${mx + ox * wall_thickness / 2.0}"/>
    <xacro:property name="wy" value="${my + oy * wall_thickness / 2.0}"/>
    <model name="${name}">
      <static>true</static>
      <pose>${wx} ${wy} ${wall_height / 2.0} 0 0 ${yaw}</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>${seg_len} ${wall_thickness} ${wall_height}</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>${seg_len} ${wall_thickness} ${wall_height}</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.55 0.15 1</ambient>
            <diffuse>0.1 0.75 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
  </xacro:macro>

  <world name="gpr_scan_polygon">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <xacro:unless value="$(arg headless)">
      <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    </xacro:unless>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 -0.3 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.2 -1.0</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.9 0.9 0.9 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Concave "M" boundary (CCW). Interior free space ends at these edges. -->
    <xacro:polygon_edge_wall name="poly_wall_0" x0="-4.0" y0="-2.0" x1="4.0" y1="-2.0"/>
    <xacro:polygon_edge_wall name="poly_wall_1" x0="4.0" y0="-2.0" x1="4.0" y1="2.5"/>
    <xacro:polygon_edge_wall name="poly_wall_2" x0="4.0" y0="2.5" x1="2.5" y1="-0.5"/>
    <xacro:polygon_edge_wall name="poly_wall_3" x0="2.5" y0="-0.5" x1="0.0" y1="2.5"/>
    <xacro:polygon_edge_wall name="poly_wall_4" x0="0.0" y0="2.5" x1="-2.5" y1="-0.5"/>
    <xacro:polygon_edge_wall name="poly_wall_5" x0="-2.5" y0="-0.5" x1="-4.0" y1="2.5"/>
    <xacro:polygon_edge_wall name="poly_wall_6" x0="-4.0" y0="2.5" x1="-4.0" y1="-2.0"/>

    <!-- Interior obstacles (unknown to planner until observed via /scan). -->
    <xacro:static_box_obstacle name="obstacle_1" x="-3.0" y="0.6" sx="0.6" sy="0.5" sz="0.5"/>
    <xacro:static_box_obstacle name="obstacle_2" x="3.0" y="0.6" sx="0.6" sy="0.5" sz="0.5"/>
    <xacro:static_box_obstacle name="obstacle_3" x="0.0" y="-1.1" sx="0.7" sy="0.4" sz="0.5"/>
    <xacro:static_box_obstacle name="obstacle_4" x="-1.2" y="1.3" sx="0.45" sy="0.45" sz="0.5"/>
    <xacro:static_box_obstacle name="obstacle_5" x="1.2" y="1.3" sx="0.45" sy="0.45" sz="0.5" r="0.55" g="0.35" b="0.2"/>

  </world>
</sdf>
