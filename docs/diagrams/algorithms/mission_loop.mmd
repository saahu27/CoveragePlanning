flowchart TB
  subgraph startup [Startup — coverage_mission.xml]
    WFM[WaitForMap<br/>perception.has_grid]
    GIC[GenerateInitialCoverage<br/>BoustrophedonPlanner → SegmentCatalog]
  end

  subgraph loop [Mission loop 2 Hz]
    HW{HasWorkRemaining?<br/>recovery_skips less than 12}
    USC[UpdateSegmentCatalog<br/>PlanningEngine.update_from_grid<br/>→ catalog.update_blocked]
    subgraph sched [Schedule if needed — Fallback]
      SNR{ScheduleNeedsRebuild?<br/>dead job / empty queue + work}
      RS[RecomputeSchedule<br/>async planning worker]
      OK[schedule unchanged]
    end
    subgraph exec [Execute — Fallback with recovery]
      ENJ[ExecuteNextJob<br/>transit then coverage]
      REC[CancelControl → SkipCurrentJob<br/>mark job blocked force_replan<br/>recovery_skips++]
      RSR[RecomputeSchedule urgent]
    end
  end

  subgraph shutdown [Shutdown]
    MC[MissionComplete + KPI report]
    RH[ReturnToStart optional A* home]
  end

  WFM --> GIC --> HW
  HW -->|no| MC --> RH
  HW -->|yes| USC
  USC --> SNR
  SNR -->|yes| RS --> ENJ
  SNR -->|no| OK --> ENJ
  ENJ -->|SUCCESS| HW
  ENJ -->|FAILURE| REC --> RSR --> HW
